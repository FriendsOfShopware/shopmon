{
  "mcpServers": {
    "shadcn": {
      "command": "npx",
      "args": [
        "shadcn-vue@latest",
        "mcp"
      ]
    },
    "opensafari": {
      "command": "npx",
      "args": [
        "-y",
        "opensafari-mcp",
        "serve"
      ]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest"]
    }
  }
}

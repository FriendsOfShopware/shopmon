FROM golang:1.26-alpine AS build

WORKDIR /app
COPY api/go.mod api/go.sum ./
RUN go mod download

COPY api/ .
RUN CGO_ENABLED=0 go build -ldflags="-s -w" -o /shopmon .

FROM gcr.io/distroless/static-debian13:nonroot

COPY --from=build /shopmon /usr/local/bin/shopmon

EXPOSE 8080
ENTRYPOINT ["shopmon"]
CMD ["server"]
